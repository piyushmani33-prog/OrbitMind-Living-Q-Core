# OrbitMind Living Q-Core — example environment configuration.
# Copy to ".env" for local development:  cp .env.example .env
# NEVER commit a real ".env". No secret values belong in this example file.

# Application
ORBITMIND_APP_NAME=OrbitMind Living Q-Core
ORBITMIND_ENV=local
ORBITMIND_LOG_LEVEL=INFO
ORBITMIND_LOG_JSON=false

# Execution mode: "local" (default). Reserved for future "cloud" portability.
ORBITMIND_EXECUTION_MODE=local

# Database. SQLite for the local vertical slice; PostgreSQL is the production target.
# Example production value (do NOT set locally unless Postgres is provisioned):
#   ORBITMIND_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/orbitmind
ORBITMIND_DATABASE_URL=sqlite:///./data/orbitmind.db

# Artifact storage (must stay inside the project; path traversal is rejected).
ORBITMIND_ARTIFACTS_DIR=./artifacts

# Mission demonstration limits (safety bounds on propagation requests).
ORBITMIND_MAX_PROPAGATION_HOURS=48
ORBITMIND_MIN_STEP_SECONDS=10
ORBITMIND_MAX_STEP_SECONDS=3600
ORBITMIND_MAX_SAMPLES=20000

# Quantum adapter (optional). Self-test is never run on API requests.
ORBITMIND_QUANTUM_ENABLED=false

# --- Network safety (Phase 2). DISABLED by default. ---
# A live CelesTrak request happens ONLY when BOTH switches below are true.
ORBITMIND_NETWORK_ENABLED=false
ORBITMIND_CELESTRAK_ENABLED=false

# CelesTrak connector (endpoint is configurable; verify against official docs).
ORBITMIND_CELESTRAK_BASE_URL=https://celestrak.org/NORAD/elements/gp.php
ORBITMIND_CELESTRAK_CONNECT_TIMEOUT_SECONDS=5.0
ORBITMIND_CELESTRAK_READ_TIMEOUT_SECONDS=10.0
ORBITMIND_CELESTRAK_MAX_RETRIES=2
ORBITMIND_CELESTRAK_CACHE_TTL_SECONDS=7200
# CelesTrak checks for new GP data only every 2h; the policy floors this at 7200s.
ORBITMIND_CELESTRAK_MIN_REFRESH_SECONDS=7200
ORBITMIND_CELESTRAK_MAX_RESPONSE_BYTES=1048576

# --- JPL Solar System Dynamics connectors (Phase 3A). DISABLED by default. ---
# A live JPL request happens ONLY when ORBITMIND_NETWORK_ENABLED and the matching
# source switch below are both true. SBDB switch governs lookup AND constrained query.
ORBITMIND_JPL_SBDB_ENABLED=false
ORBITMIND_JPL_CAD_ENABLED=false
ORBITMIND_JPL_SBDB_BASE_URL=https://ssd-api.jpl.nasa.gov/sbdb.api
ORBITMIND_JPL_SBDB_QUERY_BASE_URL=https://ssd-api.jpl.nasa.gov/sbdb_query.api
ORBITMIND_JPL_CAD_BASE_URL=https://ssd-api.jpl.nasa.gov/cad.api
ORBITMIND_JPL_CACHE_TTL_SECONDS=86400
ORBITMIND_JPL_MIN_REFRESH_SECONDS=3600
ORBITMIND_JPL_MAX_RESULTS=200

# Controlled cache directory for raw source payloads (metadata stored in the DB).
ORBITMIND_CACHE_DIR=./cache

# --- Scientific memory (Phase 3B). ---
# PostgreSQL is the production system-of-record; SQLite is the default for unit tests
# and basic local development (ADR-0018/0023). To use a local PostgreSQL profile:
#   docker compose --profile postgres up -d
# then set (LOCAL-ONLY, throwaway placeholder credentials — never commit real ones).
# Host port is 55432 (not 5432). On Windows use 127.0.0.1, NOT localhost (IPv6 timeout):
#   ORBITMIND_DATABASE_URL=postgresql+psycopg://orbitmind:orbitmind@127.0.0.1:55432/orbitmind
# Docker Compose reads these for the local PostgreSQL service:
POSTGRES_USER=orbitmind
POSTGRES_PASSWORD=orbitmind
POSTGRES_DB=orbitmind

# Ingestion is allowlisted to approved roots; secret-like files are rejected.
# Embeddings / vector search are DISABLED by default (null provider; ADR-0022).
ORBITMIND_MEMORY_EMBEDDINGS_ENABLED=false
ORBITMIND_MEMORY_MAX_FILE_BYTES=2000000
ORBITMIND_MEMORY_FTS_LANGUAGE=english
