# OrbitMind Living Q-Core — example environment configuration.
# Copy to ".env" for local development:  cp .env.example .env
# NEVER commit a real ".env". No secret values belong in this example file.

# Application
ORBITMIND_APP_NAME=OrbitMind Living Q-Core
ORBITMIND_ENV=local
ORBITMIND_LOG_LEVEL=INFO
ORBITMIND_LOG_JSON=false

# Execution mode: "local" (default). Reserved for future "cloud" portability.
ORBITMIND_EXECUTION_MODE=local

# Database. SQLite for the local vertical slice; PostgreSQL is the production target.
# Example production value (do NOT set locally unless Postgres is provisioned):
#   ORBITMIND_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/orbitmind
ORBITMIND_DATABASE_URL=sqlite:///./data/orbitmind.db

# Artifact storage (must stay inside the project; path traversal is rejected).
ORBITMIND_ARTIFACTS_DIR=./artifacts

# Mission demonstration limits (safety bounds on propagation requests).
ORBITMIND_MAX_PROPAGATION_HOURS=48
ORBITMIND_MIN_STEP_SECONDS=10
ORBITMIND_MAX_STEP_SECONDS=3600
ORBITMIND_MAX_SAMPLES=20000

# Quantum adapter (optional). Self-test is never run on API requests.
ORBITMIND_QUANTUM_ENABLED=false
