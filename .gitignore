# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Test / coverage / type / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/

# --- Local databases (never commit) ---
*.db
*.sqlite
*.sqlite3
*.db-journal
data/*.db
data/*.sqlite3

# --- Generated mission artifacts (never commit) ---
/artifacts/*
!/artifacts/.gitkeep

# --- Source cache (raw external payloads; never commit) ---
/cache/*
!/cache/.gitkeep

# --- Secrets / local environment (never commit) ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- IDE / OS ---
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# --- Tooling ---
.python-version
node_modules/
